# ---------- LLM Providers ----------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx          # required (primary)
OPENAI_API_KEY=sk-xxxxxxxx                 # optional (fallback / judge cross-check)
# GOOGLE_API_KEY: Google AI Studio (Gemini) key from https://aistudio.google.com/apikey (own line: a blank value + inline # captures the comment)
GOOGLE_API_KEY=
PRIMARY_PROVIDER=anthropic                 # anthropic | openai | google | local
FALLBACK_PROVIDER=openai                   # anthropic | openai | google | local | none  (e.g. google primary + local fallback -> quota/429 auto-switches to local)
GENERATOR_MODEL=claude-sonnet-4-20250514   # model for Agent 2 (the one always-on LLM)
JUDGE_MODEL=claude-sonnet-4-20250514       # model for the Judge (used only in hybrid/llm mode)
LLM_TEMPERATURE=0.7                        # generator creativity
JUDGE_TEMPERATURE=0.0                      # judge determinism
LLM_MAX_TOKENS=4096
LLM_TOP_P=0.95                             # nucleus sampling cap (Gemini's own default); lower = tighter output
# Tiered model routing (cost control): heavy = hard creative work (script), light = mechanical
# / high-volume calls (JSON repair, judge scoring). Empty => reuse GENERATOR_MODEL / JUDGE_MODEL.
LLM_TIERING_ENABLED=true
# MODEL_HEAVY / MODEL_LIGHT: optional per-tier overrides; leave BLANK to reuse GENERATOR_MODEL /
# JUDGE_MODEL. Do NOT put an inline # comment on a blank value line (it becomes the value).
MODEL_HEAVY=
MODEL_LIGHT=
# Local / self-hosted LLM (free, runs on your machine). Set PRIMARY_PROVIDER=local (or use it as
# FALLBACK_PROVIDER). Works with any OpenAI-compatible server: Ollama, LM Studio, vLLM, llama.cpp.
# LOCAL_LLM_MODEL is used for every call (cloud GENERATOR/JUDGE/MODEL_HEAVY/LIGHT names are ignored).
LOCAL_LLM_BASE_URL=http://localhost:11434/v1   # Ollama; LM Studio: http://localhost:1234/v1
LOCAL_LLM_MODEL=llama3.1                    # name of a model you've pulled locally (e.g. `ollama pull llama3.1`)
LOCAL_LLM_API_KEY=local                     # dummy is fine; most local servers ignore it (vLLM may need a real one)
# GOOGLE_MODELS: comma-separated, best-first Gemini models tried in order — on ANY error (quota/429,
# bad id, network) the chain moves to the next, then to FALLBACK_PROVIDER once all are exhausted. Each
# free-tier model has its own quota pool, so more models = more runway. Per-call tiering names ignored.
GOOGLE_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite
GOOGLE_THINKING=true                       # Gemini reasons before answering (thinkingConfig + [THINK] marker); off = faster/cheaper

# ---------- Data Sources ----------
ADZUNA_APP_ID=xxxx                         # required if adzuna enabled
ADZUNA_APP_KEY=xxxx
NEWSAPI_KEY=xxxx                           # optional
ENABLED_SOURCES=search                     # domain-agnostic default; works on ANY niche. Career add-ons: adzuna,layoffs,news,bls
LAYOFFS_FEED_URL=https://example.com/layoffs.rss
SIGNAL_CACHE_TTL_MIN=720                   # reuse cached signals within 12h
# Web search is the DEFAULT source: domain-agnostic, it queries the run's topic (niche + --idea)
# directly, so any niche works out of the box. Free via DuckDuckGo (no key); for a real index set
# SEARCH_PROVIDER=tavily|brave and the matching free API key. adzuna/layoffs/bls are career-specific
# feeds — add them to ENABLED_SOURCES only for job/tech-market videos.
SEARCH_PROVIDER=duckduckgo                 # duckduckgo (no key) | tavily | brave
TAVILY_API_KEY=                            # required only if SEARCH_PROVIDER=tavily (free tier)
BRAVE_API_KEY=                             # required only if SEARCH_PROVIDER=brave (free tier)
SEARCH_MAX_RESULTS=8                       # web results fetched per query
SEARCH_QUERY_COUNT=4                        # multi-query fan-out: total searches/run (base topic query + facets)
SEARCH_FACETS=statistics,salary,trends 2026,common mistakes,requirements,tips  # angle suffixes appended to the topic

# ---------- Research (Agent 1.5) ----------
# After the idea is picked, an LLM reads the real pages behind the brief's sources and writes a DEPTH
# report (mechanisms: how/why) the script uses to EXPLAIN, not just list tips. Grounded in fetched
# pages; degrades to snippets on failure. RESEARCH_ENABLED=false skips it.
RESEARCH_ENABLED=true
RESEARCH_MAX_SOURCES=4                     # pages fetched + read per run
RESEARCH_SOURCE_BUFFER=2                   # over-fetch this many extra, then keep the most on-topic RESEARCH_MAX_SOURCES
RESEARCH_MAX_POINTS=6                      # depth points synthesized
RESEARCH_MAX_CHARS_PER_SOURCE=4000         # chars kept per fetched page
RESEARCH_FETCH_TIMEOUT_SEC=10              # per-page fetch timeout (seconds)

# ---------- Pipeline Behavior ----------
MAX_REVISIONS=3                            # generator<->judge loop bound
JUDGE_MODE=hybrid                          # hybrid | deterministic | llm  (cost control)
PASS_THRESHOLD=3.9                         # min weighted rubric total (0-5) to PASS (stricter than the 3.75 default)
INSIGHT_MIN=3.5                            # Insight floor (0-5): a genuine "4" clears it, a "3" revises. KEEP <= 4.0: the LLM grades a
                                           # discrete 1-5, so a floor above 4 would need a perfect 5 (unreachable)
WITTINESS_MIN=2.5                          # Wittiness floor (0-5): a clear "3" clears it. A hard "4" floor here oscillates (wit is subjective)
ENDING_MIN=3.0                             # Ending floor (0-5): last scene needs a like/subscribe nudge AND a sign-off (both)
MAX_SCENE_SIMILARITY=0.45                  # two scenes more alike than this (0-1) = duplicate padding -> REVISE
GROUNDING_MIN=4.0                          # hard floor on factual grounding (0-5)
FATIGUE_LOOKBACK=5                         # # of recent runs checked for template repetition
TARGET_NICHE=tech careers                  # default content domain
BRAINSTORM_ENABLED=true                     # Agent 0 proposes a fresh, specific idea each run (fixes topic collapse); off = raw topic
BRAINSTORM_IDEA_COUNT=5                      # how many ideas to propose; on a terminal you pick one, else the first is used
SCRIPT_TARGET_WORDS=900                    # ~6-7 min video
MIN_FACTS=3                                # min grounded facts Agent 1 must produce (else the run fails)
MAX_FACTS=12                               # max grounded facts kept in the brief (more angles = less repetition)
MIN_SCENES=3                               # completeness gate: reject scripts with fewer scenes (stub guard)
MIN_SCRIPT_WORD_RATIO=0.5                  # completeness gate: reject drafts < this fraction of SCRIPT_TARGET_WORDS
GATE_RELIEF_SCORE=4.5                      # drafts scoring >= this (0-5) get slack on insight+length floors (>5 disables)
GATE_RELIEF_RATIO=0.20                     # slack amount (20%); never applies to grounding/compliance/fatigue
FAIL_FAST_SCORE=0                          # 0=off; >0 aborts revisions scoring below this on attempt >=2
REQUIRE_SCRIPT_APPROVAL=false               # true = pause after a PASS for your sign-off, then `content-foundry resume`

# ---------- Voiceover (TTS) ----------
TTS_PROVIDER=elevenlabs                     # elevenlabs | openai | edge (free,online) | piper (free,offline) | chatterbox (free voice clone)
ELEVENLABS_API_KEY=xxxx                     # required if TTS_PROVIDER=elevenlabs
TTS_VOICE_ID=Rachel                         # elevenlabs voice id, OR an edge voice e.g. en-US-AriaNeural
# Alternate the narrator by run-id parity: male for ODD run ids, female for EVEN. Blank = always use
# TTS_VOICE_ID. Use your provider's voice names (edge e.g. en-US-GuyNeural / en-US-AriaNeural).
TTS_VOICE_MALE=                             # odd run ids (0001, 0003, ...)
TTS_VOICE_FEMALE=                           # even run ids (0002, 0004, ...)
TTS_MODEL=eleven_multilingual_v2
TTS_FORMAT=mp3_44100_128
# Piper (offline TTS): `pip install piper-tts`, download a .onnx voice from
# huggingface.co/rhasspy/piper-voices, then set the path below (required only if TTS_PROVIDER=piper).
PIPER_MODEL_PATH=
PIPER_EXECUTABLE=piper
# Free zero-shot VOICE CLONING (only if TTS_PROVIDER=chatterbox): point at a short (~15-30s) clean WAV
# of your own voice; cloned locally under the MIT license (safe for a monetized channel). pip install
# chatterbox-tts. GPU strongly recommended (~5x faster) — the default `pip install torch` is CPU-ONLY;
# for CUDA install the GPU build: pip install torch torchaudio --index-url https://download.pytorch.org/whl/cu124
TTS_REFERENCE_CLIP=
TTS_CLONE_DEVICE=auto                       # auto | cuda | cpu  (cuda needs the CUDA torch build above; set cuda to hard-fail if the GPU isn't visible instead of silently using CPU)
TTS_CLONE_EXAGGERATION=0.5                  # 0.5 neutral; higher = more expressive
TTS_CLONE_CFG=0.5                           # lower (~0.3) = steadier pacing
TTS_SILENCE_PAD_MS=150                       # silence kept each side of a chunk when trimming dead air; higher = softer, less abrupt sentence transitions

# ---------- Visuals ----------
IMAGE_PROVIDER=pollinations                  # openai | stability | google | pollinations | none  (pollinations = FREE AI thumbnail, no key)
IMAGE_FALLBACK_PROVIDER=none                  # optional fallback if the primary fails; e.g. google primary + pollinations fallback (Imagen needs a PAID plan)
GOOGLE_IMAGE_MODEL=imagen-4.0-fast-generate-001  # only if IMAGE_PROVIDER=google (needs a PAID plan; Imagen paid-only, Nano Banana blocked on free tier)
STABILITY_API_KEY=xxxx                       # required if IMAGE_PROVIDER=stability
PEXELS_API_KEY=xxxx                          # optional B-roll
PIXABAY_API_KEY=                             # optional 2nd free B-roll source (more variety across videos)
# COVERR_API_KEY (optional 3rd free B-roll source): request a key at team@coverr.co; Coverr asks for attribution.
COVERR_API_KEY=
BROLL_POOL_SIZE=24                           # candidate clips fetched per query (more variety; each clip used at most once)
BROLL_DIRECTOR_ENABLED=true                  # LLM re-writes each scene's B-roll queries from the whole script (relevance + cross-scene diversity)
BROLL_DIRECTOR_MAX_QUERIES=8                  # ordered B-roll shots the director plans per scene (more, shorter clips)
THUMBNAIL_DIRECTOR_ENABLED=true              # LLM writes a rich, per-video thumbnail image prompt (quality > the generic template; hard no-text rule kills baked-in gibberish); falls back to the template
VISUAL_STYLE=clean infographic, high-contrast, bold text
SCENES_PER_VIDEO=10                          # target number of distinct visuals
# A fixed signature line spoken first in every video (prepended to scene 1, works on any topic).
INTRO_ENABLED=true                           # set false to let each script open on its own first line
INTRO_TAGLINE=No fluff, let's get straight into it.
# CREATOR_BIO: your real background/credentials, woven in SUBTLY for authority (blank = fully generic).
CREATOR_BIO=
# CREATOR_TITLE_TAG: short credibility tag some titles/thumbnails may carry (e.g. "FAANG AI Scientist").
CREATOR_TITLE_TAG=
THUMBNAIL_SIZE=1280x720
SHORTS_THUMBNAIL_SIZE=1080x1920                # vertical 9:16 thumbnail for a Short (matches the frame)

# ---------- Content format: long-form video vs vertical Shorts ----------
# ONE switch selects the whole output shape. "long" = the standard 16:9 video (nothing else changes).
# "short" = a vertical 9:16 YouTube Short from the SAME pipeline: one tight ~50s idea + big burned
# captions. Override per run with: content-foundry run --format short
CONTENT_FORMAT=long                           # long | short
SHORTS_RESOLUTION=1080x1920                    # vertical 9:16
SHORTS_TARGET_WORDS=100                        # ~35-45s of narration (Shorts retain best when short)
SHORTS_SCENES=4
SHORTS_MAX_DURATION_SEC=50                     # target ceiling (hard max is 3 min)
SHORTS_BURN_CAPTIONS=true                      # big captions on (Shorts are watched muted)
SHORTS_INTRO_ENABLED=false                     # skip the fixed tagline; a Short hooks in the first second
SHORTS_SCENE_TRANSITION=none                   # fast hard cuts read better than slow blends
# SHORTS_HASHTAG: appended to the Short's description so YouTube classifies it as a Short.
SHORTS_HASHTAG=#Shorts

# ---------- Render ----------
RENDER_BACKEND=ffmpeg                         # ffmpeg | moviepy | avatar
# FFMPEG_PATH: optional explicit path to ffmpeg(.exe). Leave blank to auto-discover (PATH + common
# install dirs) — handy on Windows when a fresh terminal hasn't picked up the installer's PATH yet.
FFMPEG_PATH=
VIDEO_ENCODER=auto                            # auto = GPU encoder if ffmpeg has one (h264_nvenc/qsv/amf), else libx264 (CPU); auto-falls back to CPU
AVATAR_PROVIDER=none                          # none | heygen | did
HEYGEN_API_KEY=xxxx                           # required if RENDER_BACKEND=avatar & AVATAR_PROVIDER=heygen
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=30
VIDEO_SPEED=1.0                               # play the whole output faster/slower (1.5 = 1.5x; audio pitch preserved)
CAPTIONS_ENABLED=false                        # off: YouTube auto-CC is free & synced. Enable only with a timing-capable voice (ElevenLabs/Edge); Chatterbox/Piper even-split and drift. Source citations burn regardless.
CITATION_SECONDS=7                            # top source strip: seconds shown from when the stat is spoken (domain only, no TLD)
RENDER_FALLBACK=true                          # avatar timeout -> ffmpeg backend
# Scene polish (render-only: re-render an existing run with --from-stage render to apply)
SCENE_TRANSITION=none                         # none | fade | fadewhite | fadeblack | dissolve | slideleft ...
SCENE_TRANSITION_SEC=0.5                      # crossfade length between scenes (0.1-2.0s)
COLOR_WARMTH=0.0                              # warm grade: 0 = neutral, 1 = strongly warm/amber
SUBSCRIBE_NUDGE_ENABLED=false                 # small "Subscribe" badge that fades in at the midpoint
SUBSCRIBE_NUDGE_SEC=4                         # seconds the badge stays on screen
SUBSCRIBE_NUDGE_POSITION=bottom-center        # top/bottom + left/right/center
SUBSCRIBE_BELL_ENABLED=true                   # ring a bell the moment the badge fades in (needs SFX_ENABLED)
SUBSCRIBE_BELL_SOUND=bell                     # SFX keyword for the chime: "bell" -> bell.mp3 in SFX_DIR
# Personal avatar overlay: composite a fixed image into a corner of every frame.
# Supply your own PNG (transparent background recommended); rendering skips it if absent.
AVATAR_OVERLAY_ENABLED=false
AVATAR_IMAGE_PATH=assets/avatar.png           # path to your avatar PNG (relative to project root)
AVATAR_POSITION=bottom-right                  # long-form corner (top-left | top-right | bottom-left | bottom-right); Shorts auto-pin TOP-RIGHT
AVATAR_SCALE=0.18                             # avatar height as a fraction of the video height (Shorts use 1/2 of this)
AVATAR_MARGIN=24                              # px padding from the frame edges
THUMBNAIL_USE_AVATAR=true                     # composite your avatar face into the thumbnail (skipped if the file is absent)
THUMBNAIL_AVATAR_SCALE=0.5                     # avatar height as a fraction of the thumbnail (smaller = less dominant; needs a transparent PNG or `pip install rembg`)

# ---------- Sound effects ----------
# The script author (Agent 2) writes short 'sfx' cue keywords into scenes; the renderer mixes the
# matching clip in at that scene's start. Ships with a local library in data/sounds; an optional
# Freesound key lets it download anything the library is missing (Pixabay has no SFX API, so drop
# any Pixabay downloads straight into data/sounds).
SFX_ENABLED=false                             # true = author + mix sound effects into the video
SFX_DIR=data/sounds                           # local folder of .mp3/.wav/.ogg/.m4a/.flac clips
FREESOUND_API_KEY=                            # optional: fetch missing effects from freesound.org
SFX_VOLUME_DB=-4.0                            # gain applied to each effect relative to narration
YOUTUBE_CLIENT_SECRETS_FILE=secrets/client_secrets.json
YOUTUBE_TOKEN_FILE=secrets/youtube_token.json
PUBLISH_MODE=draft                            # draft | auto  (draft = upload then stop for approval)
YOUTUBE_PRIVACY_STATUS=private                # private | unlisted | public
YOUTUBE_CATEGORY_ID=22                        # 22 = People & Blogs
YOUTUBE_DEFAULT_LANGUAGE=en
REQUIRE_MANUAL_DISCLOSURE_BEFORE_PUBLIC=true  # hard gate: never auto-publish public without disclosure
# Pull viewers deeper into the channel: append a subscribe + explore CTA to EVERY description (long
# and Short). Blank YOUTUBE_CHANNEL_URL => a generic subscribe line (no link).
CHANNEL_CTA_ENABLED=true
# YOUTUBE_CHANNEL_URL: your channel/handle URL for the CTA link (e.g. https://www.youtube.com/@YourHandle).
YOUTUBE_CHANNEL_URL=
CHANNEL_CTA_TEXT=Subscribe for more, and explore the channel for the full deep-dive videos.
# PUBLISH_TOP_COMMENT: also post the CTA as a top comment (best-effort). Needs the youtube.force-ssl
# scope, so turning it ON means deleting the OAuth token to re-consent (see Human_Tasks). The API
# cannot PIN a comment — pin it once in Studio. Default off.
PUBLISH_TOP_COMMENT=false

# ---------- Proven-idea mining (optional; read-only YouTube Data API v3 — no scraping) ----------
# Offers REAL outlier videos (views far above a channel's own median) as pre-vetted, proof-tagged
# options in the idea picker — e.g. "Are devices listening to you  [Veritasium — 5M views, 8x avg]".
# Needs only a public Data-API key (NOT the OAuth publish credentials). Create one at
# https://console.cloud.google.com > APIs & Services > Credentials > API key, with "YouTube Data
# API v3" enabled. Blank key OR IDEA_MINING_ENABLED=false => the picker is unchanged.
IDEA_MINING_ENABLED=false
# Read-only Data-API key (leave blank to disable mining):
YOUTUBE_API_KEY=
# Optional: pin channels (comma @handles / URLs / UC… ids). BLANK (default) => search VIDEOS by your
# topic and keep the ones that beat their own channel's average — the topic-locked, most relevant mode:
IDEA_MINING_CHANNELS=
IDEA_MINING_SEARCH_RESULTS=25                  # topical video candidates vetted (blank-channels mode)
IDEA_MINING_MAX_CHANNELS=6                     # channels sampled ONLY when you pin channels above
IDEA_MINING_VIDEOS_PER_CHANNEL=30             # recent uploads sampled per channel for its median
IDEA_MINING_OUTLIER_MULTIPLE=3.0              # a video qualifies at >= N x its channel's median views
IDEA_MINING_MAX_IDEAS=5                        # cap on proven ideas shown in the picker

# ---------- Notifications (free Telegram bot) ----------
NOTIFY_ENABLED=true
NOTIFIER=telegram                          # telegram | none
TELEGRAM_BOT_TOKEN=xxxx                    # from @BotFather (free)
TELEGRAM_CHAT_ID=xxxx                      # your chat / user id
NOTIFY_EVENTS=run_complete,need_validation,video_uploaded,low_credits,run_failed

# ---------- Credit / Budget Monitoring ----------
MONTHLY_BUDGET_USD=20                       # alert when projected monthly spend exceeds this
LOW_CREDIT_THRESHOLD_PCT=80                 # fire low_credits alert at this % of budget
ENFORCE_BUDGET_CAP=true                     # hard-stop a run once estimated month-to-date spend hits the budget

# ---------- Storage ----------
DATABASE_URL=sqlite:///data/content_foundry.db
OUTPUT_DIR=output/runs

# ---------- Safeguards / Compliance ----------
REQUIRE_DISCLOSURE=true                    # force synthetic-content disclosure block
REQUIRE_GROUNDING=true                     # reject ungrounded statistical claims

# ---------- Content strategy (titles, discoverability) ----------
TIME_BOX_ENABLED=true                      # year-stamp titles (e.g. "...in 2026"); keep advice evergreen
CONTENT_YEAR=0                             # 0 => current UTC year
SEO_OPTIMIZE_ENABLED=true                  # deterministic title/tags/chapters/hashtags (no LLM)
SEO_MAX_TAGS=15                            # cap on YouTube tags
SEO_TITLE_MAX_CHARS=70                     # title length budget (SERP/thumbnail friendly)
SEO_ADD_CHAPTERS=true                      # add chapter timestamps when scenes qualify (>=3, each >=10s)
# CHANNEL_KEYWORDS: comma list of evergreen channel tags (optional); leave blank if unused.
CHANNEL_KEYWORDS=

# ---------- Ops ----------
LOG_LEVEL=INFO                             # DEBUG|INFO|WARNING|ERROR
LOG_FORMAT=json                            # json|console
SCHEDULE_CRON=0 9 * * MON                  # weekly Monday 09:00 (used by scheduler)

# ---------- Optional: split secrets file ----------
# ENV_FILE=secrets/credentials.env         # point Settings at an out-of-repo dotenv
